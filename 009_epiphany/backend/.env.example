# ===== AI Providers =====
# 必須。BALTHASAR-2 と MODERATOR は Claude を使用。
# 他プロバイダのキーが無い場合、全ノードが Claude にフォールバックします。
ANTHROPIC_API_KEY=sk-ant-...

# 任意。設定すると MELCHIOR-1 が実際の OpenAI(ChatGPT) になります。
OPENAI_API_KEY=

# 任意。設定すると CASPER-3 が実際の Gemini になります。
GEMINI_API_KEY=

# ===== Database =====
# 自動判定: postgresql:// → Postgres / sqlite:// → SQLite(ローカル) / 未設定 → メモリ。
# ローカル開発（再起動後も残す）:
DATABASE_URL=sqlite:///./epiphany.db
# 本番(Railway): Postgres プラグインが ${{Postgres.DATABASE_URL}} を自動注入する。

# ===== Server =====
# 本番ではフロントの公開URLを必ず追加すること（カンマ区切り可）。
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000
# PORT は Railway が自動注入する（ローカルのみ 8000）。
PORT=8000

# 各ノードで使うモデル（上書き可）
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o
GEMINI_MODEL=gemini-2.5-flash

# Web検索（任意）: 既定で有効・キー不要(DuckDuckGo)
ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_RESULTS=5
